{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/envHook.py || exit 2"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx skills find \"fastapi best practices\")",
      "Bash(npx skills find \"python microservice\")",
      "Bash(npx skills add fastapi/fastapi@fastapi -y)",
      "Bash(npx skills add ofershap/fastapi-best-practices@fastapi-best-practices -y)",
      "Bash(docker compose logs backend)",
      "Bash(docker compose exec postgres psql -U postgres -d ai_chat -c \"\\\\dt\")",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(mkdir -p services)",
      "Bash(cp -r backend services/chat-service)",
      "Bash(docker compose:*)",
      "Bash(npm install:*)",
      "Bash(claude mcp:*)",
      "mcp__playwright",
      "Bash(cd:*)",
      "Bash(curl:*)",
      "Bash(docker exec:*)"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  }
}
